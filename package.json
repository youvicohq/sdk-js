{
  "name": "@youvico",
  "version": "1.1.1",
  "private": true,
  "description": "YouViCo JavaScript SDK workspace",
  "packageManager": "pnpm@10.30.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/youvicohq/sdk-js.git"
  },
  "workspaces": [
    "packages/api"
  ],
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:api": "pnpm --filter @youvico/api build",
    "clean:api": "pnpm --filter @youvico/api clean",
    "lint": "pnpm -r --if-present lint",
    "format:api": "pnpm --filter @youvico/api format",
    "lint:api": "pnpm --filter @youvico/api lint",
    "pack:api": "pnpm --filter @youvico/api pack --dry-run",
    "bump": "node scripts/bump.mjs",
    "test": "pnpm test:scripts && pnpm -r --if-present test",
    "test:scripts": "node --test scripts/*.test.mjs",
    "test:api": "pnpm --filter @youvico/api test",
    "typecheck": "pnpm -r --if-present typecheck",
    "typecheck:api": "pnpm --filter @youvico/api typecheck"
  }
}
